# --- Wallet ---
# BIP39 mnemonic for the desk agent. Leave empty to auto-generate on first run
# (the generated phrase is printed once — back it up).
WALLET_MNEMONIC=

# --- Network ---
SPHERE_NETWORK=testnet            # mainnet | testnet | dev

# --- Escrow agent (own coordinator) ---
# The v2 testnet escrow isn't shipped yet, so we run our own escrow agent that
# holds both legs and pays them out atomically (npm run escrow). This is the
# nametag the desk registers the swap with and both parties deposit to.
ESCROW_AGENT=hau-escrow
# Escrow's own wallet + storage (separate from the desk/taker).
ESCROW_MNEMONIC=
ESCROW_DATA_DIR=./escrow-data
ESCROW_TOKENS_DIR=./escrow-tokens
ESCROW_DEVICE_ID=hau-escrow-node

# Aggregator/oracle API key for authenticated gateway requests (token ops).
# Testnet value is in the SDK's own .env.example; without it the SDK warns and
# runs unauthenticated (init still works).
ORACLE_API_KEY=

# Wallet-api rails — REQUIRED to send/RECEIVE v2 token transfers. Nostr only
# carries messaging/nametags; tokens are delivered via the wallet-api mailbox.
WALLET_API_URL=https://wallet-api.unicity.network
# Stable per-device id (persist it to avoid re-auth each launch).
DEVICE_ID=hau-otc-desk-node

# Extra Nostr relays (comma-separated) — NOT needed for transfers (those go via
# wallet-api). Leave empty. (sphere-relay is the NIP-29 group-chat relay and
# requires auth — adding it just spams "auth-required".)
NOSTR_RELAYS=

# --- Desk identity ---
DESK_NAMETAG=otc-desk             # registered on first run if available

# --- Storage (Node providers) ---
DATA_DIR=./wallet-data
TOKENS_DIR=./tokens

# Desk durable state (reservations, limits, in-flight deals).
STATE_FILE=./wallet-data/desk-state.json

# --- Safety rails ---
# Hash-chained, tamper-evident audit log (JSON Lines).
AUDIT_FILE=./wallet-data/audit.jsonl
# Circuit breaker: auto-halt after this many consecutive swap failures.
MAX_CONSEC_FAILURES=3
# P&L breaker: auto-halt when the day's mark-to-market loss reaches this (USDU).
MAX_DAILY_LOSS_USDU=5000
# How often to mark inventory and check the P&L breaker (ms).
PNL_INTERVAL_MS=30000

# Pre-lock: block a swap if the counterparty can't be verified before we lock.
# Set to 'false' to run in warn-only mode (audited, but proceeds).
REQUIRE_VERIFICATION=true
# Manual kill: create this file to pause the desk, remove it to resume.
#   touch ./wallet-data/HALT   → pause
#   rm    ./wallet-data/HALT   → resume
CONTROL_FILE=./wallet-data/HALT

# How often to reconcile the ledger's free balances against the chain (ms).
TRUEUP_INTERVAL_MS=60000

# Price feed quorum: min venues that must respond for the median to be used.
# 1 = keep quoting on a single venue (more available); 2 = require both
# (safer, but refuses to quote if a venue is down).
MIN_PRICE_SOURCES=1

# --- Price feed ---
# Manual reference mid for the illiquid UCT token (no CEX market). The desk
# quotes mid ± spread around this. Liquid pairs (BTC/ETH) come live from the
# Crypto.com public API automatically — see buildLivePriceFeed() in index.ts.
UCT_USDU_MID=1.25
